---
// Header.astro — Global navigation with mega menu for all pages except homepage
const currentPath = Astro.url.pathname;

const solutions = [
  {
    slug: 'hr-settlers', name: 'HR Settlers',
    tagline: 'Enter the Dutch market with confidence',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>'
  },
  {
    slug: 'hr-teams', name: 'HR Teams',
    tagline: 'Your outsourced HR department',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
  },
  {
    slug: 'hr-reset', name: 'HR Reset',
    tagline: 'Modernize your existing HR',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>'
  },
  {
    slug: 'hr-sos', name: 'HR S.O.S.',
    tagline: 'Urgent HR crisis support',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>'
  }
];

const industries = [
  { slug: 'technology', name: 'Technology & Startups', icon: 'terminal' },
  { slug: 'life-sciences', name: 'Life Sciences & Pharma', icon: 'biotech' },
  { slug: 'finance', name: 'Finance & Fintech', icon: 'account_balance' },
  { slug: 'professional-services', name: 'Professional Services', icon: 'work' },
  { slug: 'logistics', name: 'Logistics & Supply Chain', icon: 'local_shipping' },
  { slug: 'ngo', name: 'NGO & Non-Profit', icon: 'public' },
  { slug: 'manufacturing', name: 'Greenfield & Manufacturing', icon: 'precision_manufacturing' },
  { slug: 'industrial', name: 'Production & Industrial', icon: 'engineering' },
];

import { getFeaturedArticles } from '../lib/wordpress';

const featuredArticles = await getFeaturedArticles();

const resourceLinks = [
  { label: 'Our Expertise', icon: 'star', href: '/resources/expertise' },
  { label: 'Case Studies', icon: 'trending_up', href: '/resources/case-studies' },
  { label: 'Blog', icon: 'article', href: '/blog' },
  { label: 'FAQ', icon: 'help', href: '/resources/faq' },
];

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo">
      <img src="/images/logo.png" alt="HRHelp" class="logo-img" />
    </a>

    <!-- Navigation with Mega Menus -->
    <nav class="header-nav" id="header-nav">
      <!-- Solutions (mega menu) -->
      <div class="nav-item has-mega">
        <a href="/solutions" class:list={['nav-link', { active: currentPath.startsWith('/solutions') }]}>
          Solutions
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <div class="mega-panel mega-solutions">
          <div class="mega-inner">
            <div class="mega-section-label">Our Solutions</div>
            <div class="mega-solutions-grid">
              {solutions.map(s => (
                <a href={`/solutions/${s.slug}`} class="mega-sol-card">
                  <div class="mega-sol-icon" set:html={s.icon} />
                  <div class="mega-sol-text">
                    <span class="mega-sol-name">{s.name}</span>
                    <span class="mega-sol-tagline">{s.tagline}</span>
                  </div>
                </a>
              ))}
            </div>
            <div class="mega-footer">
              <a href="/solutions" class="mega-footer-link">
                View All Solutions
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/contact" class="mega-footer-cta">
                Free Consultation
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Industries (mega menu) -->
      <div class="nav-item has-mega">
        <a href="/industries" class:list={['nav-link', { active: currentPath.startsWith('/industries') }]}>
          Industries
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <div class="mega-panel mega-industries">
          <div class="mega-inner">
            <div class="mega-section-label">Industry Expertise</div>
            <div class="mega-industries-grid">
              {industries.map(ind => (
                <a href={`/industries/${ind.slug}`} class="mega-ind-item">
                  <span class="mega-ind-icon material-symbols-outlined">{ind.icon}</span>
                  <span class="mega-ind-name">{ind.name}</span>
                </a>
              ))}
            </div>
            <div class="mega-footer">
              <a href="/industries" class="mega-footer-link">
                Explore All Industries
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Resources (mega menu) -->
      <div class="nav-item has-mega">
        <a href="/resources" class:list={['nav-link', { active: currentPath.startsWith('/resources') }]}>
          Resources
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <div class="mega-panel mega-resources">
          <div class="mega-inner">
            <div class="mega-res-layout">
              <!-- Featured articles -->
              <div class="mega-res-featured">
                <div class="mega-section-label">Featured Articles</div>
                <div class="mega-res-articles">
                  {featuredArticles.map(article => (
                    <a href={article.href} class="mega-res-card">
                      <div class="mega-res-img">
                        <img src={article.image} alt={article.title} />
                        <span class="mega-res-cat">{article.category}</span>
                      </div>
                      <span class="mega-res-title">{article.title}</span>
                    </a>
                  ))}
                </div>
              </div>
              <!-- Quick Links -->
              <div class="mega-res-links">
                <div class="mega-section-label">Quick Links</div>
                {resourceLinks.map(link => (
                  <a href={link.href} class="mega-res-link-item">
                    <span class="material-symbols-outlined mega-res-link-icon">{link.icon}</span>
                    <span>{link.label}</span>
                  </a>
                ))}
              </div>
            </div>
            <div class="mega-footer">
              <a href="/resources" class="mega-footer-link">
                Visit Resource Center
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Simple links -->
      {navLinks.map(link => (
        <div class="nav-item">
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </div>
      ))}
    </nav>

    <!-- Right side -->
    <div class="header-actions">
      <a href="/contact" class="btn btn-primary btn-sm">Free Consultation</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<div class="mobile-menu" id="mobile-menu">
  <nav class="mobile-nav">
    <!-- Solutions accordion -->
    <div class="mobile-accordion">
      <button class="mobile-accordion-trigger" aria-expanded="false">
        Solutions
        <svg class="mobile-acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="mobile-accordion-content">
        {solutions.map(s => (
          <a href={`/solutions/${s.slug}`} class="mobile-sub-link">
            <span class="mobile-sub-icon" set:html={s.icon} />
            {s.name}
          </a>
        ))}
        <a href="/solutions" class="mobile-sub-all">View All Solutions →</a>
      </div>
    </div>

    <!-- Industries accordion -->
    <div class="mobile-accordion">
      <button class="mobile-accordion-trigger" aria-expanded="false">
        Industries
        <svg class="mobile-acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="mobile-accordion-content">
        {industries.map(ind => (
          <a href={`/industries/${ind.slug}`} class="mobile-sub-link">
            <span class="material-symbols-outlined mobile-sub-mat-icon">{ind.icon}</span>
            {ind.name}
          </a>
        ))}
        <a href="/industries" class="mobile-sub-all">Explore All Industries →</a>
      </div>
    </div>

    <!-- Resources accordion -->
    <div class="mobile-accordion">
      <button class="mobile-accordion-trigger" aria-expanded="false">
        Resources
        <svg class="mobile-acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="mobile-accordion-content">
        {resourceLinks.map(link => (
          <a href={link.href} class="mobile-sub-link">
            <span class="material-symbols-outlined mobile-sub-mat-icon">{link.icon}</span>
            {link.label}
          </a>
        ))}
        <a href="/resources" class="mobile-sub-all">Visit Resource Center →</a>
      </div>
    </div>

    <a href="/about" class:list={['mobile-nav-link', { active: currentPath.startsWith('/about') }]}>About</a>
    <a href="/contact" class:list={['mobile-nav-link', { active: currentPath.startsWith('/contact') }]}>Contact</a>

    <a href="/contact" class="btn btn-primary" style="margin-top: 1rem; width: 100%; justify-content: center;">
      Free Consultation
    </a>
  </nav>
</div>

<style>
  /* ═══════════════════════════════════════
     BASE HEADER
     ═══════════════════════════════════════ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: all var(--transition-base);
  }

  .site-header.scrolled {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
  }

  .header-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .header-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header-logo .logo-img {
    height: 38px;
    width: auto;
    display: block;
  }

  /* ═══════════════════════════════════════
     NAVIGATION
     ═══════════════════════════════════════ */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--gray-600);
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
    letter-spacing: 0.2px;
    text-decoration: none;
    cursor: pointer;
  }

  .nav-link:hover {
    color: var(--navy);
    background: var(--gray-50);
  }

  .nav-link.active {
    color: var(--orange);
    font-weight: 600;
  }

  .chevron {
    transition: transform 0.25s ease;
    opacity: 0.5;
    flex-shrink: 0;
  }

  .nav-item.has-mega:hover .chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* ═══════════════════════════════════════
     MEGA PANEL — shared styles
     ═══════════════════════════════════════ */
  .mega-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s ease;
    z-index: 999;
    padding-top: 12px; /* hover bridge */
  }

  .nav-item.has-mega:hover .mega-panel,
  .nav-item.has-mega:focus-within .mega-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .mega-inner {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12), 0 4px 20px rgba(0, 0, 0, 0.06);
    overflow: hidden;
  }

  .mega-section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    color: var(--gray-400);
    padding: 1.25rem 1.5rem 0.75rem;
  }

  .mega-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.5rem;
    background: var(--gray-50);
    border-top: 1px solid var(--gray-100);
  }

  .mega-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mega-footer-link:hover {
    color: var(--orange);
  }

  .mega-footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--white);
    background: var(--orange);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mega-footer-cta:hover {
    background: var(--navy);
  }

  /* ═══════════════════════════════════════
     SOLUTIONS MEGA MENU
     ═══════════════════════════════════════ */
  .mega-solutions {
    width: 520px;
  }

  .mega-solutions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    padding: 0 0.75rem 0.75rem;
  }

  .mega-sol-card {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.9rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mega-sol-card:hover {
    background: var(--gray-50);
  }

  .mega-sol-icon {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--orange), #ff9a4d);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
  }

  .mega-sol-icon svg {
    width: 20px;
    height: 20px;
  }

  .mega-sol-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mega-sol-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.3;
  }

  .mega-sol-tagline {
    font-size: 0.78rem;
    color: var(--gray-500);
    line-height: 1.4;
  }

  .mega-sol-card:hover .mega-sol-name {
    color: var(--orange);
  }

  /* ═══════════════════════════════════════
     INDUSTRIES MEGA MENU
     ═══════════════════════════════════════ */
  .mega-industries {
    width: 520px;
  }

  .mega-industries-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 0 0.5rem 0.5rem;
  }

  .mega-ind-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mega-ind-item:hover {
    background: var(--gray-50);
  }

  .mega-ind-icon {
    width: 34px;
    height: 34px;
    min-width: 34px;
    border-radius: 8px;
    background: rgba(15, 43, 70, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px !important;
    color: var(--orange);
    transition: all 0.2s ease;
  }

  .mega-ind-item:hover .mega-ind-icon {
    background: var(--navy);
    color: var(--white);
  }

  .mega-ind-name {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--navy);
    line-height: 1.3;
  }

  .mega-ind-item:hover .mega-ind-name {
    color: var(--orange);
  }

  /* ═══════════════════════════════════════
     RESOURCES MEGA MENU
     ═══════════════════════════════════════ */
  .mega-resources {
    width: 660px;
  }

  .mega-res-layout {
    display: flex;
    gap: 0;
  }

  .mega-res-featured {
    flex: 1;
    border-right: 1px solid var(--gray-100);
  }

  .mega-res-articles {
    display: flex;
    gap: 0.5rem;
    padding: 0 1rem 1rem;
  }

  .mega-res-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: all 0.2s ease;
    flex: 1;
    padding: 0.4rem;
  }

  .mega-res-card:hover {
    background: var(--gray-50);
  }

  .mega-res-img {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--gray-100);
  }

  .mega-res-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .mega-res-card:hover .mega-res-img img {
    transform: scale(1.05);
  }

  .mega-res-cat {
    position: absolute;
    top: 6px;
    left: 6px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--white);
    background: var(--orange);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  .mega-res-title {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mega-res-card:hover .mega-res-title {
    color: var(--orange);
  }

  .mega-res-links {
    min-width: 190px;
    padding-right: 0.5rem;
  }

  .mega-res-link-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
    margin: 0 0.5rem;
  }

  .mega-res-link-item:hover {
    background: var(--gray-50);
  }

  .mega-res-link-icon {
    font-size: 20px !important;
    color: var(--orange);
    width: 28px;
    height: 28px;
    min-width: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(244, 121, 32, 0.08);
    border-radius: 6px;
  }

  .mega-res-link-item span:not(.material-symbols-outlined) {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--navy);
  }

  .mega-res-link-item:hover span:not(.material-symbols-outlined) {
    color: var(--orange);
  }

  /* ═══════════════════════════════════════
     RIGHT SIDE
     ═══════════════════════════════════════ */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════
     MOBILE TOGGLE
     ═══════════════════════════════════════ */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 1001;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  .mobile-toggle.open span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle.open span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ═══════════════════════════════════════
     MOBILE MENU OVERLAY
     ═══════════════════════════════════════ */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--white);
    z-index: 999;
    padding: 1rem 1.5rem 2rem;
    opacity: 0;
    transform: translateY(-10px);
    transition: all var(--transition-base);
    overflow-y: auto;
  }

  .mobile-menu.open {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Mobile accordion */
  .mobile-accordion {
    border-bottom: 1px solid var(--gray-100);
  }

  .mobile-accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 1rem 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--navy);
    cursor: pointer;
    text-align: left;
  }

  .mobile-acc-chevron {
    transition: transform 0.3s ease;
    color: var(--gray-400);
  }

  .mobile-accordion-trigger[aria-expanded="true"] .mobile-acc-chevron {
    transform: rotate(180deg);
    color: var(--orange);
  }

  .mobile-accordion-content {
    display: none;
    padding: 0 0 0.75rem 0.5rem;
  }

  .mobile-accordion-content.open {
    display: block;
  }

  .mobile-sub-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.6rem 0.5rem;
    text-decoration: none;
    color: var(--gray-600);
    font-size: 0.92rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .mobile-sub-link:hover {
    color: var(--orange);
    background: var(--gray-50);
  }

  .mobile-sub-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--orange);
  }

  .mobile-sub-icon svg {
    width: 18px;
    height: 18px;
  }

  .mobile-sub-mat-icon {
    font-size: 20px !important;
    color: var(--orange);
    width: 28px;
    text-align: center;
  }

  .mobile-sub-all {
    display: block;
    padding: 0.6rem 0.5rem;
    color: var(--orange);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .mobile-nav-link {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--navy);
    padding: 1rem 0;
    border-bottom: 1px solid var(--gray-100);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--orange);
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 900px) {
    .header-nav,
    .header-actions {
      display: none;
    }

    .mobile-toggle {
      display: flex;
    }

    .mobile-menu {
      display: block;
      pointer-events: none;
    }

    .mobile-menu.open {
      pointer-events: all;
    }
  }
</style>

<script>
  // Scroll effect
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  // Mobile toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('open');
    menu?.classList.toggle('open');
    document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
  });

  // Mobile accordions
  document.querySelectorAll('.mobile-accordion-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      // Close all other accordions
      document.querySelectorAll('.mobile-accordion-trigger').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          other.nextElementSibling?.classList.remove('open');
        }
      });
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      btn.nextElementSibling?.classList.toggle('open');
    });
  });
</script>
