---
import Layout from '../components/Layout.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "HRHelp.nl",
  "image": "https://hrhelp.nl/images/og-default.png",
  "url": "https://hrhelp.nl",
  "telephone": "+31-85-760-8188",
  "email": "info@hrhelp.nl",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Televisieweg 2",
    "addressLocality": "Almere",
    "postalCode": "1322 AC",
    "addressCountry": "NL"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:30",
    "closes": "18:00"
  },
  "priceRange": "$$",
  "description": "Expert HR consulting for international companies in the Netherlands. Employment law, payroll, compliance, talent acquisition.",
  "knowsAbout": ["Dutch Employment Law", "30% Ruling", "HR Consulting", "Payroll", "Restructuring", "Sickness Management"]
};
---

<Layout title="Your HR Partner in the Netherlands" description="Expert HR consulting for international companies in the Netherlands. Employment law, payroll, compliance, talent acquisition — all handled by Dutch HR experts." homeHeader={true} schema={localBusinessSchema}>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-panel glass-panel animate-fade-in-up">
      <span class="eyebrow-badge animate-fade-in-up">Premium HR Consulting</span>
      <h1 class="animate-fade-in-up animate-delay-1">Your HR Partner in the <span class="text-orange">Netherlands</span></h1>
      <p class="hero-desc animate-fade-in-up animate-delay-2">From hiring your first employee to managing a full Dutch workforce — we handle the HR so you can focus on growth.</p>
      <div class="hero-buttons animate-fade-in-up animate-delay-3">
        <a href="/contact" class="btn btn-primary btn-lg">
          Get Expert Support
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <button type="button" class="btn btn-secondary btn-lg" id="hero-wp-btn" style="cursor:pointer; display:inline-flex; align-items:center; gap:0.4rem;">
          <span class="material-symbols-outlined" style="font-size:18px;">download</span>
          Download Free Guide
        </button>
      </div>
      <div class="hero-trust animate-fade-in-up animate-delay-4">
        <div class="trust-logos">
          <div class="trust-logo-circle">
            <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" fill="white" font-weight="800" font-size="10" font-family="Inter, Arial, sans-serif">LG</text></svg>
          </div>
          <div class="trust-logo-circle">
            <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" fill="white" font-weight="700" font-size="7" font-family="Inter, Arial, sans-serif">LIME</text></svg>
          </div>
          <div class="trust-logo-circle">
            <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" fill="white" font-weight="800" font-size="5.5" font-family="Inter, Arial, sans-serif">SANDVIK</text></svg>
          </div>
          <div class="trust-logo-circle trust-logo-more">+5</div>
        </div>
        <div>
          <strong>Trusted by 75+</strong>
          <span>International Companies</span>
        </div>
      </div>
    </div>
    <div class="hero-badges">
      <a href="/resources/expertise/leadership-training" class="hero-badge" style="text-decoration:none;">
        <div class="badge-icon badge-green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5"/></svg>
        </div>
        <div>
          <span class="badge-label">TRAINING</span>
          <strong>Leadership Development</strong>
        </div>
      </a>
      <a href="/resources/expertise/restructuring" class="hero-badge hero-badge-bottom" style="text-decoration:none;">
        <div class="badge-icon badge-blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="11" x2="19" y2="17"/></svg>
        </div>
        <div>
          <span class="badge-label">RESULT</span>
          <strong>50% Restructuring Savings</strong>
        </div>
      </a>
      <a href="/resources/expertise/sickness-management" class="hero-badge hero-badge-third" style="text-decoration:none;">
        <div class="badge-icon" style="background: rgba(34,197,94,0.15); color: #22c55e;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div>
          <span class="badge-label">IMPACT</span>
          <strong>€500K Saved on Absence</strong>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- Client Logos Section -->
<section class="client-logos">
  <div class="container">
    <p class="logos-label">Trusted by teams at leading organizations worldwide</p>
    <div class="logos-track">
      <div class="logos-slide">
        <!-- Viacom -->
        <div class="logo-item">
          <svg viewBox="0 0 140 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="23" font-family="Inter, Arial, sans-serif" font-weight="800" font-size="22" letter-spacing="3">VIACOM</text></svg>
        </div>
        <!-- Lime -->
        <div class="logo-item">
          <svg viewBox="0 0 90 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="23" font-family="Inter, Arial, sans-serif" font-weight="700" font-size="24">Lime</text></svg>
        </div>
        <!-- LG -->
        <div class="logo-item">
          <svg viewBox="0 0 50 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="24" font-family="Inter, Arial, sans-serif" font-weight="800" font-size="26">LG</text></svg>
        </div>
        <!-- Gate Gourmet -->
        <div class="logo-item">
          <svg viewBox="0 0 180 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="22" font-family="Inter, Arial, sans-serif" font-weight="600" font-size="18" letter-spacing="1">GateGourmet</text></svg>
        </div>
        <!-- Harman -->
        <div class="logo-item">
          <svg viewBox="0 0 140 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="23" font-family="Inter, Arial, sans-serif" font-weight="800" font-size="22" letter-spacing="2">HARMAN</text></svg>
        </div>
        <!-- C.H. Robinson -->
        <div class="logo-item">
          <svg viewBox="0 0 200 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="23" font-family="Inter, Arial, sans-serif" font-weight="700" font-size="20" letter-spacing="1">C.H. ROBINSON</text></svg>
        </div>
        <!-- Sandvik -->
        <div class="logo-item">
          <svg viewBox="0 0 140 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="23" font-family="Inter, Arial, sans-serif" font-weight="800" font-size="22" letter-spacing="2">SANDVIK</text></svg>
        </div>
        <!-- China Eastern -->
        <div class="logo-item">
          <svg viewBox="0 0 200 30" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><text x="0" y="22" font-family="Inter, Arial, sans-serif" font-weight="600" font-size="17" letter-spacing="1">CHINA EASTERN</text></svg>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- What We Handle Section -->
<section class="what-we-handle section-navy">
  <div class="container">
    <div class="handle-header">
      <div>
        <span class="eyebrow" style="color: var(--orange);">What We Handle</span>
        <h2>Every Aspect of Dutch HR, Covered</h2>
      </div>
      <p>From day-to-day compliance to complex employment law — we take it all off your plate.</p>
    </div>
    <div class="handle-carousel">
      <div class="handle-track">

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h4>Sickness Management</h4>
          <p>Navigate the Dutch 2-year sick leave obligation, Wet Poortwachter compliance, and reintegration processes.</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v4M12 19v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M1 12h4M19 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          </div>
          <h4>30% Ruling</h4>
          <p>Maximize tax benefits for expat employees with specialized application processing and eligibility assessment.</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h4>Employment Contracts</h4>
          <p>Ironclad agreements fully compliant with Dutch law and Collective Labour Agreements (CAO).</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h4>HR Policies</h4>
          <p>Employee handbooks, leave policies, remote work agreements, and workplace regulations tailored to NL law.</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h4>Training & Development</h4>
          <p>Compliance training, cultural integration workshops, and management development programs.</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h4>Payroll Management</h4>
          <p>End-to-end Dutch payroll, tax withholding, holiday allowance, pension contributions, and year-end reporting.</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          </div>
          <h4>Dismissal Procedures</h4>
          <p>UWV and court-based dismissals, settlement agreements (vaststellingsovereenkomst), and transition payments.</p>
        </div>

        <div class="handle-card">
          <div class="handle-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
          </div>
          <h4>Compliance Audits</h4>
          <p>Full HR compliance review against Dutch employment law, GDPR, and industry-specific regulations.</p>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Services Section -->
<section class="services section-white">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Our Solutions</span>
      <h2>Tailored HR Support for<br/>Every Stage of Your Journey</h2>
      <p>From market entry to full HR outsourcing, we have you covered.</p>
    </div>
    <div class="services-grid">
      <a href="/solutions/hr-settlers" class="service-card-v2">
        <div class="sv2-illus-wrap sv2-illus-navy">
          <img src="/images/illus-settlers.png" alt="HR Settlers" class="sv2-illus" />
        </div>
        <div class="sv2-content">
          <h3>HR Settlers</h3>
          <span class="sv2-badge">Market Entry</span>
          <p>Complete HR setup for companies opening their first Netherlands office — from entity registration to your first hire.</p>
          <span class="sv2-link">Learn More →</span>
        </div>
      </a>

      <a href="/solutions/hr-teams" class="service-card-v2">
        <div class="sv2-illus-wrap sv2-illus-blue">
          <img src="/images/illus-teams.png" alt="HR Teams" class="sv2-illus" />
        </div>
        <div class="sv2-content">
          <h3>HR Teams</h3>
          <span class="sv2-badge">Outsourced HR</span>
          <p>Your dedicated HR department. From employee relations and policy development to strategic HR planning.</p>
          <span class="sv2-link">Learn More →</span>
        </div>
      </a>

      <a href="/solutions/hr-reset" class="service-card-v2">
        <div class="sv2-illus-wrap sv2-illus-orange">
          <img src="/images/illus-reset.png" alt="HR Reset" class="sv2-illus" />
        </div>
        <div class="sv2-content">
          <h3>HR Reset</h3>
          <span class="sv2-badge">Transformation</span>
          <p>Audit and modernize your existing HR. Fix compliance gaps, update contracts, and optimize your processes.</p>
          <span class="sv2-link">Learn More →</span>
        </div>
      </a>

      <a href="/solutions/hr-sos" class="service-card-v2">
        <div class="sv2-illus-wrap sv2-illus-red">
          <img src="/images/illus-sos.png" alt="HR S.O.S." class="sv2-illus" />
        </div>
        <div class="sv2-content">
          <h3>HR S.O.S.</h3>
          <span class="sv2-badge sv2-badge-red">Urgent Support</span>
          <p>Same-day response for HR emergencies — dismissal procedures, workplace conflicts, and legal disputes.</p>
          <span class="sv2-link">Learn More →</span>
        </div>
      </a>
    </div>
    <p class="services-cta-text">Not sure which solution fits? <a href="/contact" class="link-arrow">Book a free discovery call →</a></p>
  </div>
</section>

<!-- Industries Section -->
<section class="industries section-navy">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow" style="color: var(--orange);">Industry Expertise</span>
      <h2>Specialized HR for Your Sector</h2>
      <p>Deep vertical expertise for the industries that call the Netherlands home.</p>
    </div>
    <div class="industries-grid">
      <a href="/industries/technology" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
        <h4>Technology & Startups</h4>
        <p>Seed to scale-up HR. Stock options, tech talent acquisition, rapid growth support.</p>
      </a>
      <a href="/industries/life-sciences" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 0 0 6 6 6 6 0 0 0 6-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg></div>
        <h4>Life Sciences & Pharma</h4>
        <p>Compliance-focused for regulated industries. R&D tax benefits, clinical workforce.</p>
      </a>
      <a href="/industries/finance" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
        <h4>Finance & Fintech</h4>
        <p>AFM/DNB compliance, executive compensation, banking-grade HR governance.</p>
      </a>
      <a href="/industries/professional-services" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
        <h4>Professional Services</h4>
        <p>Consulting, legal, and advisory firms. Partnership structures, billable workforce.</p>
      </a>
      <a href="/industries/logistics" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
        <h4>Logistics & Supply Chain</h4>
        <p>Distribution centers, shift workers, temporary labor, port operations HR.</p>
      </a>
      <a href="/industries/ngo" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg></div>
        <h4>NGO & Non-Profit</h4>
        <p>Non-profit employment rules, volunteer management, grant-funded positions.</p>
      </a>
      <a href="/industries/manufacturing" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20M5 20V8l5 4V8l5 4V4l5 4v12"/></svg></div>
        <h4>Greenfield & Manufacturing</h4>
        <p>New facility HR setup, production workforce, CLA negotiations, works councils.</p>
      </a>
      <a href="/industries/industrial" class="industry-card">
        <div class="icon-box icon-box-sm"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
        <h4>Production & Industrial</h4>
        <p>Health & safety compliance, union relations, blue-collar recruitment.</p>
      </a>
    </div>
    <div class="industries-cta">
      <a href="/industries" class="btn btn-ghost">See how we've helped companies in your industry →</a>
    </div>
  </div>
</section>

<!-- Process Section -->
<section class="process section-cream">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Our Process</span>
      <h2>Seamless Integration Roadmap</h2>
      <p>From first conversation to ongoing partnership, here's how we work.</p>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">01</div>
        <div class="icon-box icon-box-lg">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h4>Discovery Call</h4>
        <p>Free 30-minute call to understand your business, timeline, and specific HR needs.</p>
        <span class="step-time">Day 1</span>
      </div>
      <div class="process-connector"></div>
      <div class="process-step">
