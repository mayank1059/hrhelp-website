        document.body.removeChild(link);

        // Change button to success state
        btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:18px;">check_circle</span> Downloaded!';
        btn.style.background = '#2e7d32';
      } else {
        status.style.display = 'block';
        status.style.background = '#fce4ec';
        status.style.color = '#c62828';
        status.textContent = '✗ ' + (result.message || 'Please check your details.');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        btn.style.opacity = '1';
      }
    })
    .catch(function() {
      status.style.display = 'block';
      status.style.background = '#fce4ec';
      status.style.color = '#c62828';
      status.textContent = '✗ Network error. Please try again.';
      btn.disabled = false;
      btn.innerHTML = originalHTML;
      btn.style.opacity = '1';
    });
  });
})();
</script>


