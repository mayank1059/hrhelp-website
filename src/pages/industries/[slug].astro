export function getStaticPaths() {
  return [
    { params: { slug: 'technology' } },
    { params: { slug: 'life-sciences' } },
    { params: { slug: 'finance' } },
    { params: { slug: 'professional-services' } },
    { params: { slug: 'logistics' } },
    { params: { slug: 'ngo' } },
    { params: { slug: 'manufacturing' } },
    { params: { slug: 'industrial' } },
  ];
}

const { slug } = Astro.params;
const ind = industryData[slug];
if (!ind) return Astro.redirect('/industries');

// Find related industries (exclude current)
const allSlugs = Object.keys(industryData);
const relatedSlugs = allSlugs.filter(s => s !== slug).slice(0, 3);
const related = relatedSlugs.map(s => ({ slug: s, ...industryData[s] }));

const industrySchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${ind.name} HR Consulting`,
  "description": ind.description,
  "provider": {
    "@type": "Organization",
    "name": "HRHelp.nl",
    "url": "https://hrhelp.nl"
  },
  "areaServed": { "@type": "Country", "name": "Netherlands" },
  "serviceType": "HR Consulting",
  "url": `https://hrhelp.nl/industries/${slug}`
};
---

<Layout title={`${ind.name} — HR Consulting`} description={ind.description} schema={industrySchema}>

<!-- ===== HERO ===== -->
<section class="idp-hero section-navy">
  <div class="idp-hero-pattern"></div>
  <div class="idp-hero-mesh"></div>
  <div class="container-wide idp-hero-inner">
    <div class="idp-hero-text" data-animate="fade-right">
      <span class="eyebrow-badge" style="border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85);">
        <span class="idp-dot"></span> <span class="material-symbols-outlined" style="font-size:16px; vertical-align: middle;">{ind.icon}</span> {ind.name}
      </span>
      <h1>{ind.tagline}</h1>
      <p>{ind.description}</p>
      <div class="idp-hero-btns">
        <a href="/contact" class="btn btn-primary btn-lg">Schedule Consultation <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span></a>
        <a href="/solutions" class="btn btn-ghost btn-lg">View Solutions</a>
      </div>
    </div>
    <div class="idp-hero-image" data-animate="fade-left">
      <img src={ind.heroImage} alt={`${ind.name} industry`} />
      <div class="idp-hero-image-overlay"></div>
      <div class="idp-hero-card">
        <div class="idp-hero-card-icon">
          <span class="material-symbols-outlined" style="color: var(--orange); font-size:20px">trending_up</span>
        </div>
        <div>
          <p class="idp-hero-card-value">{ind.complianceScore}</p>
          <p class="idp-hero-card-label">{ind.complianceLabel}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== STATS BAR ===== -->
<section class="idp-stats">
  <div class="container">
    <div class="idp-stats-grid">
      {ind.stats.map((stat: any, i: number) => (
        <div class="idp-stat-item">
          <span class={`idp-stat-value ${stat.highlight ? 'highlight' : ''}`}>{stat.value}</span>
          <span class="idp-stat-label">{stat.label}</span>
          {i < ind.stats.length - 1 && <div class="idp-stat-divider"></div>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== CHALLENGES ===== -->
<section class="idp-challenges section-cream">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="eyebrow" style="color: var(--orange);">Industry Challenges</span>
      <h2>Key HR Pain Points in {ind.name}</h2>
      <p>Identifying critical friction points in your organizational structure before they cause systemic failure.</p>
