---
import Layout from '../../components/Layout.astro';
import { getBlogPosts } from '../../lib/wordpress';

const posts = await getBlogPosts();
---

<Layout title="Blog & Insights" description="Expert articles, guides, and insights on Dutch employment law, HR strategy, and managing international teams in the Netherlands.">

<!-- ===== HERO ===== -->
<section class="blog-hero">
  <div class="blog-hero-mesh"></div>
  <div class="container" style="position: relative; z-index: 2; text-align: center;">
    <span class="eyebrow-badge" style="border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85);">
      Knowledge & Insights
    </span>
    <h1>HR <span style="color: var(--orange);">Blog</span></h1>
    <p class="blog-hero-sub">Expert guides, practical insights, and essential updates on Dutch employment law and international HR management.</p>
  </div>
</section>

<!-- ===== BLOG GRID ===== -->
<section class="blog-section">
  <div class="container">
    <div class="blog-grid">
      {posts.map((post, i) => (
        <a href={`/resources/blog/${post.slug}`} class="blog-card" data-animate="fade-up" data-delay={i * 100}>
          <div class="blog-card-img">
            <img src={post.image} alt={post.title} />
            <span class="blog-cat">{post.category}</span>
          </div>
          <div class="blog-card-body">
            <div class="blog-meta">
              <span>{post.date}</span>
              <span class="blog-dot">·</span>
              <span>{post.readTime}</span>
            </div>
            <h2>{post.title}</h2>
            <p>{post.excerpt.slice(0, 140)}...</p>
            <span class="blog-read-link">Read Article →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="blog-cta">
  <div class="container" style="text-align: center;">
    <h2>Need Expert HR Advice?</h2>
    <p>Our team is ready to help you navigate Dutch employment law and build a compliant, thriving workforce.</p>
    <a href="/contact" class="btn btn-primary btn-lg" style="margin-top: 1.5rem;">Get in Touch →</a>
  </div>
</section>

</Layout>

<style>
.blog-hero {
  padding: 10rem 0 5rem;
  background: var(--navy); color: white;
  position: relative; overflow: hidden;
}
.blog-hero-mesh {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(244,121,32,0.15), transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(255,255,255,0.05), transparent 40%);
  z-index: 1;
}
.blog-hero h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; margin-top: 1rem; color: white; }
.blog-hero-sub { font-size: 1.15rem; color: rgba(255,255,255,0.7); max-width: 560px; margin: 1rem auto 0; line-height: 1.7; }

.blog-section { padding: var(--section-padding); background: var(--cream); }
.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

.blog-card {
  text-decoration: none;
  background: white; border-radius: var(--radius-xl);
  overflow: hidden; border: 1px solid var(--gray-200);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex; flex-direction: column;
}
.blog-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.08);
}
.blog-card-img {
  height: 220px; overflow: hidden; position: relative;
}
.blog-card-img img { width: 100%; height: 100%; object-fit: cover; }

.blog-cat {
  position: absolute; top: 1rem; left: 1rem;
  background: var(--orange); color: white;
  font-size: 0.7rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  padding: 0.3rem 0.7rem; border-radius: 4px;
}

.blog-card-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
.blog-meta {
  display: flex; align-items: center; gap: 0.4rem;
  font-size: 0.78rem; color: var(--text-secondary);
  margin-bottom: 0.75rem;
}
.blog-dot { opacity: 0.5; }
.blog-card-body h2 { font-size: 1.15rem; font-weight: 700; color: var(--navy); margin-bottom: 0.5rem; line-height: 1.3; }
.blog-card-body p { font-size: 0.88rem; line-height: 1.6; color: var(--text-secondary); margin-bottom: 1rem; flex: 1; }
.blog-read-link { font-size: 0.85rem; font-weight: 700; color: var(--orange); }

.blog-cta { padding: 5rem 0; background: var(--navy); color: white; }
.blog-cta h2 { margin-bottom: 0.75rem; color: white; }
.blog-cta p { color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto; }

@media (max-width: 992px) { .blog-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; } }
</style>
