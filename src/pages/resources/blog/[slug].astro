---
import Layout from '../../../components/Layout.astro';
import { getBlogPosts, getBlogPost } from '../../../lib/wordpress';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map(p => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const post = await getBlogPost(slug as string);
if (!post) return Astro.redirect('/resources/blog');

// Get other posts for "Related Articles"
const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter(p => p.slug !== slug).slice(0, 2);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt,
  "image": post.image.startsWith('http') ? post.image : `https://hrhelp.nl${post.image}`,
  "author": {
    "@type": "Organization",
    "name": post.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "HRHelp.nl",
    "logo": { "@type": "ImageObject", "url": "https://hrhelp.nl/favicon.svg" }
  },
  "datePublished": post.date,
  "mainEntityOfPage": `https://hrhelp.nl/resources/blog/${slug}`
};
---

<Layout title={`${post.title} | Blog`} description={post.excerpt} ogImage={post.image} schema={articleSchema}>

<!-- ===== HERO ===== -->
<section class="bp-hero">
  <div class="bp-hero-mesh"></div>
  <div class="bp-hero-img">
    <img src={post.image} alt={post.title} />
    <div class="bp-hero-overlay"></div>
  </div>
  <div class="container bp-hero-inner">
    <div class="bp-hero-content">
      <span class="bp-cat">{post.category}</span>
      <h1>{post.title}</h1>
      <div class="bp-meta">
        <span class="material-symbols-outlined" style="font-size:18px;">person</span>
        <span>{post.author}</span>
        <span class="bp-dot">·</span>
        <span class="material-symbols-outlined" style="font-size:18px;">calendar_today</span>
        <span>{post.date}</span>
        <span class="bp-dot">·</span>
        <span class="material-symbols-outlined" style="font-size:18px;">schedule</span>
        <span>{post.readTime}</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== CONTENT ===== -->
<section class="bp-content-section">
  <div class="container">
    <div class="bp-layout">
      <article class="bp-article" set:html={post.content} />

      <aside class="bp-sidebar">
        <div class="bp-sidebar-card">
          <h3>Need Help?</h3>
          <p>Our HR experts are ready to assist with any questions about Dutch employment law and HR management.</p>
          <a href="/contact" class="btn btn-primary" style="width: 100%; text-align: center;">Book a Consultation →</a>
        </div>

        <div class="bp-sidebar-card">
          <h3>Our Expertise</h3>
          <ul class="bp-sidebar-links">
            <li><a href="/resources/expertise/leadership-training">Leadership Training</a></li>
            <li><a href="/resources/expertise/restructuring">Restructuring</a></li>
            <li><a href="/resources/expertise/sickness-management">Sickness Management</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- ===== RELATED ARTICLES ===== -->
{relatedPosts.length > 0 && (
<section class="bp-related">
  <div class="container">
    <h2>Related Articles</h2>
    <div class="bp-related-grid">
      {relatedPosts.map(rp => (
        <a href={`/resources/blog/${rp.slug}`} class="bp-related-card">
          <div class="bp-related-img">
            <img src={rp.image} alt={rp.title} />
            <span class="bp-related-cat">{rp.category}</span>
          </div>
          <div class="bp-related-body">
            <div class="bp-related-meta">{rp.date} · {rp.readTime}</div>
            <h3>{rp.title}</h3>
            <span class="bp-related-link">Read Article →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<!-- ===== BACK LINK ===== -->
<section class="bp-back">
  <div class="container" style="text-align: center;">
    <a href="/resources/blog" class="btn btn-outline" style="border-color: rgba(255,255,255,0.3); color: white;">
      ← Back to All Articles
    </a>
  </div>
</section>

</Layout>

<style>
/* HERO */
.bp-hero {
  position: relative; min-height: 400px;
  display: flex; align-items: flex-end;
  overflow: hidden;
}
.bp-hero-img {
  position: absolute; inset: 0;
}
.bp-hero-img img { width: 100%; height: 100%; object-fit: cover; }
.bp-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, var(--navy) 0%, rgba(10,26,50,0.7) 50%, rgba(10,26,50,0.3) 100%);
}
.bp-hero-mesh {
  position: absolute; inset: 0; z-index: 2;
  background: radial-gradient(circle at 70% 80%, rgba(244,121,32,0.12), transparent 40%);
}
.bp-hero-inner {
  position: relative; z-index: 3;
  padding-top: 8rem;
  padding-bottom: 3rem;
}
.bp-hero-content { max-width: 700px; }
.bp-cat {
  display: inline-block;
  background: var(--orange); color: white;
  font-size: 0.7rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  padding: 0.3rem 0.7rem; border-radius: 4px;
  margin-bottom: 1rem;
}
.bp-hero h1 {
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 800; color: white;
  line-height: 1.2; margin-bottom: 1rem;
}
.bp-meta {
  display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
  color: rgba(255,255,255,0.7); font-size: 0.88rem;
}
.bp-dot { opacity: 0.4; }

/* CONTENT */
.bp-content-section { padding: var(--section-padding); background: var(--cream); }
.bp-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 3rem;
  align-items: start;
}

.bp-article {
  background: white; border-radius: var(--radius-xl);
  padding: 2.5rem; border: 1px solid var(--gray-200);
  font-size: 1.05rem; line-height: 1.8;
  color: var(--text-secondary);
}
.bp-article :global(h2) {
  font-size: 1.5rem; font-weight: 700;
  color: var(--navy); margin: 2rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--orange);
}
.bp-article :global(h2:first-child) { margin-top: 0; }
.bp-article :global(p) { margin-bottom: 1.25rem; }
.bp-article :global(ul), .bp-article :global(ol) {
  margin: 1rem 0 1.5rem; padding-left: 1.5rem;
}
.bp-article :global(li) { margin-bottom: 0.5rem; }
.bp-article :global(strong) { color: var(--navy); }

.bp-sidebar { display: flex; flex-direction: column; gap: 1.5rem; position: sticky; top: 6rem; }
.bp-sidebar-card {
  background: white; border-radius: var(--radius-xl);
  padding: 1.5rem; border: 1px solid var(--gray-200);
}
.bp-sidebar-card h3 {
  font-size: 1.05rem; font-weight: 700; color: var(--navy);
  margin-bottom: 0.75rem;
}
.bp-sidebar-card p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
.bp-sidebar-links { list-style: none; padding: 0; margin: 0; }
.bp-sidebar-links li { margin-bottom: 0.5rem; }
.bp-sidebar-links a {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.88rem; font-weight: 600; color: var(--navy);
  text-decoration: none; padding: 0.5rem 0;
  border-bottom: 1px solid var(--gray-200);
  transition: color 0.2s;
}
.bp-sidebar-links a:hover { color: var(--orange); }

/* RELATED */
.bp-related { padding: 4rem 0; background: var(--cream); }
.bp-related h2 { text-align: center; margin-bottom: 2rem; }
.bp-related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; max-width: 800px; margin: 0 auto; }
.bp-related-card {
  text-decoration: none; background: white;
  border-radius: var(--radius-xl); overflow: hidden;
  border: 1px solid var(--gray-200);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.bp-related-card:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,0.06); }
.bp-related-img { height: 180px; overflow: hidden; position: relative; }
.bp-related-img img { width: 100%; height: 100%; object-fit: cover; }
.bp-related-cat {
  position: absolute; top: 0.75rem; left: 0.75rem;
  background: var(--orange); color: white;
  font-size: 0.65rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  padding: 0.2rem 0.5rem; border-radius: 3px;
}
.bp-related-body { padding: 1.25rem; }
.bp-related-meta { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.5rem; }
.bp-related-body h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 0.5rem; line-height: 1.3; }
.bp-related-link { font-size: 0.8rem; font-weight: 700; color: var(--orange); }

.bp-back { padding: 3rem 0; background: var(--navy); }

@media (max-width: 992px) {
  .bp-layout { grid-template-columns: 1fr; }
  .bp-sidebar { position: static; }
  .bp-related-grid { grid-template-columns: 1fr; max-width: 400px; }
}
</style>
