---
import Layout from '../../components/Layout.astro';
import { getCaseStudies } from '../../lib/wordpress';

const allCaseStudies = await getCaseStudies();
const caseStudies = allCaseStudies.map(cs => ({
  slug: cs.slug,
  tag: cs.tag,
  title: cs.title,
  desc: cs.intro.slice(0, 120) + '...',
  icon: cs.icon,
  image: cs.image,
}));
---

<Layout title="Case Studies" description="Real challenges, measurable outcomes — authentic case studies from HRHelp.nl's client engagements.">

<!-- ===== HERO ===== -->
<section class="cs-hero">
  <div class="cs-hero-mesh"></div>
  <div class="container" style="position: relative; z-index: 2; text-align: center;">
    <span class="eyebrow-badge" style="border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85);">
      Our Work in Practice
    </span>
    <h1>Client <span style="color: var(--orange);">Case Studies</span></h1>
    <p class="cs-hero-sub">Real challenges, measurable outcomes — a selection of engagements that reflect how we work.</p>
  </div>
</section>

<!-- ===== CASE STUDY CARDS ===== -->
<section class="cs-section">
  <div class="container">
    <div class="cs-grid">
      {caseStudies.map((cs, i) => (
        <a href={`/resources/case-studies/${cs.slug}`} class="cs-card" data-animate="fade-up" data-delay={i * 100}>
          <div class="cs-card-img">
            <img src={cs.image} alt={cs.title} />
          </div>
          <div class="cs-card-body">
            <span class="cs-tag">
              <span class="material-symbols-outlined" style="font-size:16px; color: var(--orange);">{cs.icon}</span>
              {cs.tag}
            </span>
            <h2>{cs.title}</h2>
            <p>{cs.desc}</p>
            <span class="cs-link">Read Full Case Study →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="cs-cta">
  <div class="container" style="text-align: center;">
    <h2>Ready to See Similar Results?</h2>
    <p>Every engagement starts with understanding your unique challenge. Let's discuss how we can help.</p>
    <a href="/contact" class="btn btn-primary btn-lg" style="margin-top: 1.5rem;">Book a Free Consultation →</a>
  </div>
</section>

</Layout>

<style>
.cs-hero {
  padding: 10rem 0 5rem;
  background: var(--navy); color: white;
  position: relative; overflow: hidden;
}
.cs-hero-mesh {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 70% 20%, rgba(244,121,32,0.15), transparent 40%),
              radial-gradient(circle at 20% 80%, rgba(255,255,255,0.05), transparent 40%);
  z-index: 1;
}
.cs-hero h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; margin-top: 1rem; color: white; }
.cs-hero-sub { font-size: 1.15rem; color: rgba(255,255,255,0.7); max-width: 520px; margin: 1rem auto 0; line-height: 1.7; }

.cs-section { padding: var(--section-padding); background: var(--cream); }
.cs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

.cs-card {
  text-decoration: none;
  background: white; border-radius: var(--radius-xl);
  overflow: hidden; border: 1px solid var(--gray-200);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.cs-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.08);
}
.cs-card-img {
  height: 200px; overflow: hidden;
}
.cs-card-img img { width: 100%; height: 100%; object-fit: cover; }

.cs-card-body { padding: 1.5rem; }
.cs-tag {
  display: inline-flex; align-items: center; gap: 0.4rem;
  font-size: 0.7rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--orange); margin-bottom: 0.75rem;
}
.cs-card-body h2 { font-size: 1.15rem; font-weight: 700; color: var(--navy); margin-bottom: 0.5rem; line-height: 1.3; }
.cs-card-body p { font-size: 0.88rem; line-height: 1.6; color: var(--text-secondary); margin-bottom: 1rem; }
.cs-link { font-size: 0.85rem; font-weight: 700; color: var(--orange); }

.cs-cta { padding: 5rem 0; background: var(--navy); color: white; }
.cs-cta h2 { margin-bottom: 0.75rem; color: white; }
.cs-cta p { color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto; }

@media (max-width: 992px) { .cs-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; } }
</style>
