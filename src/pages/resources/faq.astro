---
import Layout from '../../components/Layout.astro';
import { getFAQGroups } from '../../lib/wordpress';

const faqGroups = await getFAQGroups();

// Build FAQPage schema from all FAQ items
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqGroups.flatMap(group =>
    group.items.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  )
};
---

<Layout title="FAQ | Frequently Asked Questions" description="Common questions about HRHelp.nl services, Dutch HR law, the 30% ruling, and our network organization model." schema={faqSchema}>

<!-- ===== HERO ===== -->
<section class="fq-hero">
  <div class="fq-hero-mesh"></div>
  <div class="container fq-hero-inner">
    <span class="eyebrow-badge">Help Center</span>
    <h1>Frequently Asked <br/><span class="fq-orange">Questions</span></h1>
    <p class="fq-hero-p">Everything you need to know about working with HRHelp.nl and navigating Dutch HR.</p>
  </div>
</section>

<!-- ===== FAQ LIST ===== -->
<section class="fq-content">
  <div class="container fq-narrow">
    {faqGroups.map(group => (
      <div class="fq-group">
        <h2 class="fq-group-title">{group.category}</h2>
        <div class="fq-list">
          {group.items.map(faq => (
            <details class="fq-item">
              <summary>
                <span>{faq.q}</span>
                <span class="material-symbols-outlined fq-arrow">expand_more</span>
              </summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    ))}

    <div class="fq-cta-card">
      <div class="fq-cta-inner">
        <h3>Still have questions?</h3>
        <p>Our senior consultants are ready to discuss your specific organizational challenges.</p>
        <div class="fq-cta-btns">
          <a href="/contact" class="btn btn-primary btn-lg" style="box-shadow: none;">Get in Touch</a>
          <a href="tel:+31857608188" class="btn btn-ghost btn-lg">Call +31 85 760 8188</a>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
/* ===== HERO ===== */
.fq-hero {
  padding: 10rem 0 5rem;
  background: var(--navy);
  color: white;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.fq-hero-mesh {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 60% 20%, rgba(244,121,32,0.12), transparent 50%),
              radial-gradient(circle at 20% 80%, rgba(255,255,255,0.04), transparent 40%);
  z-index: 1;
}
.fq-hero-inner { position: relative; z-index: 2; }
.fq-hero h1 { font-size: 3.5rem; margin: 1.5rem 0; line-height: 1.1; color: white; }
.fq-orange { color: var(--orange); }
.fq-hero-p { font-size: 1.15rem; line-height: 1.7; color: rgba(255,255,255,0.75); max-width: 600px; margin: 0 auto; }

/* ===== CONTENT ===== */
.fq-content { padding: 6rem 0 8rem; }
.fq-narrow { max-width: 800px; }

.fq-group { margin-bottom: 4rem; }
.fq-group-title {
  font-size: 1.5rem; font-weight: 800; color: var(--navy);
  margin-bottom: 1.5rem; padding-bottom: 1rem;
  border-bottom: 2px solid var(--cream);
}

.fq-list { display: flex; flex-direction: column; gap: 0.75rem; }
.fq-item {
  background: var(--cream); border-radius: var(--radius-md);
  border: 1px solid var(--gray-200); overflow: hidden;
  transition: all 0.2s ease;
}
.fq-item:hover { border-color: var(--gray-300); }
.fq-item summary {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.25rem 1.5rem; cursor: pointer; font-weight: 700;
  font-size: 1.05rem; color: var(--navy); list-style: none;
}
.fq-item summary::-webkit-details-marker { display: none; }
.fq-arrow { transition: transform 0.2s ease; color: var(--gray-400); flex-shrink: 0; margin-left: 1rem; }
.fq-item[open] .fq-arrow { transform: rotate(180deg); }
.fq-item p {
  padding: 0 1.5rem 1.25rem; font-size: 1rem; line-height: 1.7; color: var(--gray-600); margin: 0;
}

/* ===== CTA ===== */
.fq-cta-card {
  background: var(--navy); padding: 4rem; border-radius: var(--radius-xl);
  text-align: center; color: white; margin-top: 2rem;
  box-shadow: 0 40px 80px rgba(0,0,0,0.2);
}
.fq-cta-inner { max-width: 500px; margin: 0 auto; }
.fq-cta-card h3 { font-size: 2rem; color: white; margin-bottom: 0.75rem; }
.fq-cta-card p { color: rgba(255,255,255,0.7); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem; }
.fq-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

@media (max-width: 576px) {
  .fq-hero h1 { font-size: 2.5rem; }
  .fq-cta-card { padding: 3rem 1.5rem; }
}
</style>
