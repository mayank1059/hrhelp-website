      pricing: { eyebrow: 'Modernization Investment', heading: 'HR Audit & Compliance Pricing', desc: 'Choose the depth of transformation you need — from a standalone audit to a complete HR overhaul.' },
      ideal: { eyebrow: 'Who Needs a Reset?', heading: 'Companies That Benefit from an HR Compliance Audit', desc: 'If your contracts are older than two years or you\'ve never had a formal HR audit, it\'s time for a Reset.' },
